generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  price       Float
  imageUrl    String   @default("")
  category    String   @default("Tops")
  technique   String   @default("Cyanotype")
  stockStatus String   @default("In Stock")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  heroImageUrl    String   @default("")
  heroHeadline    String   @default("Handcrafted Cyanotype Fashion")
  promoBannerText String   @default("FREE SHIPPING ON ORDERS OVER 500 DH")
  updatedAt       DateTime @updatedAt
}
